# MongoDB Connection Strings (Replace with your MongoDB Atlas URIs)
MONGODB_AUTH_URI=mongodb+srv://username:password@cluster.mongodb.net/js_auth_service?retryWrites=true&w=majority
MONGODB_CATEGORY_URI=mongodb+srv://username:password@cluster.mongodb.net/js_category_service?retryWrites=true&w=majority
MONGODB_PRODUCT_URI=mongodb+srv://username:password@cluster.mongodb.net/js_product_service?retryWrites=true&w=majority
MONGODB_CART_URI=mongodb+srv://username:password@cluster.mongodb.net/js_cart_service?retryWrites=true&w=majority
MONGODB_ORDER_URI=mongodb+srv://username:password@cluster.mongodb.net/js_order_service?retryWrites=true&w=majority

# JWT Secret (Generate a strong secret)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-256-bits

# Email Configuration (Mailtrap or SMTP)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your-mailtrap-username
MAIL_PASSWORD=your-mailtrap-password
